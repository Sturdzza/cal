---
import '../styles/global.css';
import { CalendarApp } from '../components/Calendar/CalendarApp';
import { STORAGE_KEY } from '../lib/storage';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <title>kyzzo cal</title>
    <script is:inline define:vars={{ key: STORAGE_KEY }}>
      try {
        const raw = localStorage.getItem(key);
        const s = raw ? (JSON.parse(raw).settings || {}) : {};
        const root = document.documentElement;
        if (s.theme === 'light' || s.theme === 'dark') root.setAttribute('data-theme', s.theme);
        if (s.animations === 'on' || s.animations === 'off') root.setAttribute('data-motion', s.animations);
      } catch {}
    </script>
  </head>
  <body>
    <CalendarApp client:load />
  </body>
</html>
